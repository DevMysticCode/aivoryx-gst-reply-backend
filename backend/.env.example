# ============================================================
#  Aivoryx TaxBot — Backend Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
# Railway provides this automatically in production.
# Local example: postgres://user:password@localhost:5432/aivoryx_taxbot
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# --- Google Gemini AI ---
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server ---
PORT=5000

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Production: your BigRock domain, e.g. https://aivoryx.com
# Local dev: http://localhost:5173 (Vite default)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
